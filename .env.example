NODE_ENV=production
PORT=4000
BACKEND_PORT=4000
BACKEND_PUBLIC_URL=https://your-backend-domain.com
FRONTEND_PUBLIC_URL=https://your-frontend-domain.com
NEXT_PUBLIC_API_BASE_URL=https://your-backend-domain.com/api/v1

MONGODB_URI=mongodb+srv://user:password@cluster.example.com/vastraHouse
LOG_LEVEL=info

JWT_ACCESS_SECRET=replace-with-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-at-least-32-characters
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

ADMIN_TOTP_REQUIRED=false
TOTP_ISSUER=The Vastra House

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

MERCHANDISING_NEW_ARRIVAL_DAYS=30
MERCHANDISING_BEST_SELLER_UNITS=25
MERCHANDISING_TRENDING_SCORE=100
MERCHANDISING_BADGE_JOB_INTERVAL_MINUTES=60

CART_GIFT_PACKAGING_FEE=99
ABANDONED_CART_THRESHOLD_MINUTES=60
ABANDONED_CART_JOB_INTERVAL_MINUTES=15
WISHLIST_SIGNAL_JOB_INTERVAL_MINUTES=60

RAZORPAY_KEY_ID=rzp_live_or_test_key
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
RAZORPAY_ENABLE_GATEWAY_CALLS=true
COD_MANUAL_REVIEW_THRESHOLD=10000

UPI_PAYMENT_ADDRESS=payments@vastrahouse
UPI_QR_IMAGE_URL=
BANK_ACCOUNT_NAME=The Vastra House
BANK_ACCOUNT_NUMBER=
BANK_IFSC=
BANK_NAME=
MANUAL_PAYMENT_INSTRUCTIONS=Complete the transfer, then upload the payment proof during checkout.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=The Vastra House

SHIPPING_STANDARD_FEE=99
SHIPPING_EXPRESS_FEE=199
SHIPPING_FREE_THRESHOLD=1999
