{
  "name": "@vastra/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "node -e \"if (!process.env.CI && process.env.NODE_ENV !== 'production') import('husky').then(({default: husky}) => husky())\"",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "precommit": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "seed:admin": "tsx src/scripts/seedAdmin.ts",
    "seed:storefront": "tsx src/scripts/seedStorefront.ts",
    "verify:phase4": "tsx src/scripts/verifyPhase4Cloudinary.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.16.0",
    "multer": "^2.2.0",
    "otplib": "^13.4.1",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "razorpay": "^2.9.6",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.29.0",
    "husky": "^9.1.7",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "typescript": "5.9.3",
    "tsx": "^4.20.3"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=10.0.0"
  }
}
